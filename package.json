{
  "name": "gradient",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.js",
  "bin": {
    "gradient": "./dist/cli.js"
  },
  "files": [
    "dist/*.js",
    "dist/*.d.ts",
    "dist/*.d.ts.map",
    "README.md",
    "PRD.md",
    "examples"
  ],
  "description": "Project factual agent trace events onto Git diff hunks so reviewers can see where to spend attention.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/earendil-works/gradient.git"
  },
  "homepage": "https://github.com/earendil-works/gradient#readme",
  "keywords": [
    "git",
    "ai-agent",
    "code-review",
    "diff-annotation",
    "attention-gradient",
    "git-notes"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "check": "npm test && npm run build",
    "demo": "node --experimental-strip-types src/cli.ts demo",
    "gradient": "node --experimental-strip-types src/cli.ts",
    "prepack": "npm run build",
    "test": "node --experimental-strip-types --test test/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=22.18"
  }
}
